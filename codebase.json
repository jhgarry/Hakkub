"use client";
import { useSearchParams } from 'next/navigation';

export default function CampPage() {
  const searchParams = useSearchParams();
  const filterHackaton = searchParams.get('hackaton');

  return (
    <div className="max-w-7xl mx-auto p-8 flex flex-col md:flex-row gap-8">
      {/* 팀 리스트 영역 */}
      <div className="flex-1">
        <h1 className="text-3xl font-bold mb-4">팀원 모집</h1>
        {filterHackaton && (
          <p className="mb-4 text-blue-600 font-medium">필터링: {filterHackaton} 해커톤 팀</p>
        )}
        
        <div className="space-y-4">
          {/* 가상의 팀 카드 */}
          <div className="border rounded-xl p-6">
            <h3 className="text-xl font-bold">어벤져스 팀</h3>
            <p className="text-gray-600 mt-2">최고의 AI 서비스를 만듭니다.</p>
            <div className="mt-4 flex flex-wrap gap-2">
              <span className="bg-orange-100 text-orange-600 px-2 py-1 rounded text-xs">모집중</span>
              <span className="text-xs bg-gray-100 p-1 rounded">프론트엔드 1명</span>
              <span className="text-xs bg-gray-100 p-1 rounded">디자이너 1명</span>
            </div>
          </div>
        </div>
      </div>

      {/* 팀 생성 폼 영역 */}
      <aside className="w-full md:w-80 bg-gray-50 p-6 rounded-xl h-fit">
        <h2 className="text-xl font-bold mb-4">팀 생성하기</h2>
        <form className="space-y-4">
          <input className="w-full p-2 border rounded" placeholder="팀명" required />
          <textarea className="w-full p-2 border rounded" placeholder="소개" rows={3} required />
          <div className="flex items-center gap-2">
            <input type="checkbox" id="recruiting" />
            <label htmlFor="recruiting" className="text-sm">모집 중 여부</label>
          </div>
          <input className="w-full p-2 border rounded" placeholder="모집 포지션 (예: 백엔드)" />
          <input className="w-full p-2 border rounded" placeholder="연락 링크 (Open Kakao 등)" />
          <button className="w-full bg-blue-600 text-white py-2 rounded font-bold hover:bg-blue-700 transition">생성하기</button>
        </form>
      </aside>
    </div>
  );
}
