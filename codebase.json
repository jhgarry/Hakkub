<file path="src/app/login/page.tsx">
'use client';
import { useState } from 'react';
import { supabase } from '@/lib/supabase';
import { useAuth } from '@/context/AuthContext';
import { useRouter } from 'next/navigation';
import Link from 'next/link';

export default function LoginPage() {
  const [id, setId] = useState('');
  const [pw, setPw] = useState(''); // [수정] pw 상태 추가
  const { login } = useAuth();
  const router = useRouter();

  const handleLogin = async (e: React.FormEvent) => {
    e.preventDefault();
    
    // Supabase 로그인 시도 (가공된 이메일과 pw 변수 사용)
    const { data, error } = await supabase.auth.signInWithPassword({
      email: `${id}@hackerhub.com`,
      password: pw, // 이제 pw 변수를 정상적으로 인식합니다.
    });

    if (error) return alert("로그인 실패: " + error.message);

    // 로그인 성공 시 DB에서 프로필 정보 가져오기
    const { data: profile } = await supabase
      .from('profiles')
      .select('*')
      .eq('id', data.user.id)
      .single();

    login(profile); // Context에 유저 정보 저장
    router.push('/');
  };

  return (
    <div className="max-w-md mx-auto mt-20 p-8 border rounded-2xl bg-white shadow-xl text-center">
      <h1 className="text-2xl font-bold mb-6">로그인</h1>
      <form onSubmit={handleLogin} className="space-y-4">
        <input 
          className="w-full p-3 border rounded" 
          placeholder="아이디" 
          value={id}
          onChange={(e) => setId(e.target.value)} 
        />
        <input 
          className="w-full p-3 border rounded" 
          type="password" 
          placeholder="비밀번호" 
          value={pw}
          onChange={(e) => setPw(e.target.value)} // [수정] setPw 연결
        />
        <button className="w-full py-3 bg-blue-600 text-white rounded-lg font-bold hover:bg-blue-700 transition">
          로그인
        </button>
      </form>
      <div className="mt-4 text-sm text-gray-500">
        계정이 없으신가요? <Link href="/signup" className="text-blue-600 underline">회원가입</Link>
      </div>
    </div>
  );
}
</file>

